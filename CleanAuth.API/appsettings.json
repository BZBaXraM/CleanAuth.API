{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=AuthDb;Username=postgres;Password=postgres",
    "DockerConnection": "Host=localhost;Port=5432;Database=AuthDb;Username=postgres;Password=postgres"
  },
  "JWT": {
    "Secret": "a-very-long-secret-key-that-is-at-least-64-bytes-long-which-is-required-for-hmac-sha512",
    "Issuer": "https://localhost:7228",
    "Audience": "https://localhost:7228",
    "Expiration": 120
  },
  "EmailConfig": {
    "From": "YOUR_EMAIL_ADDRESS",
    "SmtpServer": "smtp.gmail.com",
    "Port": 587,
    "UserName": "YOUR_EMAIL_ADDRESS",
    "Password": "YOUR_EMAIL_PASSWORD"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "Microsoft.EntityFrameworkCore.Migrations": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ],
    "Properties": {
      "Application": "CleanAuth.API"
    }
  }
}
